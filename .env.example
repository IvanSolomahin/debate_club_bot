# Bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Database URL (SQLite default)
DATABASE_URL=sqlite+aiosqlite:///./bot.db

# Comma-separated admin Telegram IDs (optional)
ADMIN_IDS=123456789,987654321

# Timezone for event display
TIMEZONE=Europe/Moscow

# Reminder trigger hours before event (e.g., 24 and 1)
REMINDER_HOURS=24,1

# Organization name shown during onboarding
NATIVE_ORG_NAME=ВШЭ
